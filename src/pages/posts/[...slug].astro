---
import Layout from "@/layouts/Layout.astro";
import { getCollection, getCollection as getTagsCollection } from "astro:content";
import { formatDate } from "@/utils/date";
import { Icon } from "astro-icon/components";
import Toast from "@/components/blocks/Toast.astro";
import Comments from "@/components/blocks/Comments.astro";
import TableOfContents from "@/components/blocks/TableOfContents.astro";
import site from "@/config/site";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;

// Hashnode posts store HTML in post.rendered.html / post.body
const htmlBody: string = (post.rendered?.html ?? post.body) as string;

// Resolve category from the categories collection
const allCategories = await getCollection("categories");
const categoryId = post.data.category?.id ?? "uncategorized";
const categoryMatch = allCategories.find((c) => c.id === categoryId || c.data.slug === categoryId);
const category = categoryMatch ?? { data: { slug: "uncategorized", name: "Uncategorized" } };

// Resolve tags from the tags collection
const allTags = await getTagsCollection("tags");
const tagIds: string[] = (post.data.tags ?? []).map((t: { id: string }) => t.id);
const tags = allTags.filter((t) => tagIds.includes(t.id) || tagIds.includes(t.data.slug));

// --- Transformation for Hashnode Content ---

/**
 * Transforms Hashnode's HTML blockquotes that use [!TYPE] syntax 
 * into beautifully styled callouts consistent with the Breeze theme.
 */
function transformAlerts(html: string) {
  const ALERT_CONFIG = {
    NOTE: { 
      color: "var(--callout-info)", 
      label: "Note", 
      svg: `<path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/>`
    },
    TIP: { 
      color: "var(--callout-success)", 
      label: "Tip", 
      svg: `<path fill="currentColor" d="M9 21c0 .55.45 1 1 1h4c.55 0 1-.45 1-1v-1H9v1zm3-19C8.14 2 5 5.14 5 9c0 2.38 1.19 4.47 3 5.74V17c0 .55.45 1 1 1h6c.55 0 1-.45 1-1v-2.26c1.81-1.27 3-3.36 3-5.74 0-3.86-3.14-7-7-7z"/>`
    },
    IMPORTANT: { 
      color: "var(--callout-danger)", 
      label: "Important", 
      svg: `<path fill="currentColor" d="M12 2L1 21h22L12 2zm0 17h-2v-2h2v2zm0-4h-2v-4h2v4z"/>`
    },
    WARNING: { 
      color: "var(--callout-warning)", 
      label: "Warning", 
      svg: `<path fill="currentColor" d="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"/>`
    },
    CAUTION: { 
      color: "var(--callout-danger)", 
      label: "Caution", 
      svg: `<path fill="currentColor" d="M15.73 3H8.27L3 8.27v7.46L8.27 21h7.46L21 15.73V8.27L15.73 3zM12 17.3c-.72 0-1.3-.58-1.3-1.3 0-.72.58-1.3 1.3-1.3.72 0 1.3.58 1.3 1.3 0 .72-.58 1.3-1.3 1.3zm1-4.3h-2V7h2v6z"/>`
    },
  };

  // This regex matches <blockquote> blocks starting with [!TYPE]
  // It handles both single-paragraph and multi-paragraph blockquotes.
  return html.replace(
    /<blockquote>([\s\S]*?)<\/blockquote>/gi,
    (match, innerContent) => {
      const typeMatch = innerContent.match(/\[!(NOTE|TIP|IMPORTANT|WARNING|CAUTION)\]/i);
      if (!typeMatch) return match;

      const type = typeMatch[1].toUpperCase() as keyof typeof ALERT_CONFIG;
      const config = ALERT_CONFIG[type];
      
      // Remove the marker and clean up the content
      const cleanContent = innerContent
        .replace(/\[!(NOTE|TIP|IMPORTANT|WARNING|CAUTION)\]/gi, "")
        .trim();

      // We replicate the Callout.astro component structure here
      // Note: We use raw CSS for the background to match our OKLCH logic
      return `
        <div class="custom-callout not-prose my-12 flex gap-4 rounded-xl p-6 transition-all border border-border/40" 
             style="background-color: oklch(from ${config.color} l c h / 0.08); border-left: 4px solid ${config.color};">
          <div class="flex-none text-xl mt-0.5" style="color: ${config.color}">
            <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">${config.svg}</svg>
          </div>
          <div class="flex-1">
            <div class="flex items-center gap-2 mb-2 font-extrabold tracking-widest uppercase text-[10px]" style="color: ${config.color}">
              <span class="opacity-90">${config.label}</span>
            </div>
            <div class="text-[14px] leading-relaxed font-normal text-muted-foreground/90 prose-p:mb-0">
              ${cleanContent}
            </div>
          </div>
        </div>
      `;
    }
  );
}

const finalHtml = transformAlerts(htmlBody);
---

<Layout title={post.data.title} description={post.data.summary}>
  <article
    class="animate-in fade-in mx-auto max-w-2xl overflow-x-hidden p-8 duration-1000 md:p-16"
  >
    <header class="mb-16 border-b border-border/50 pb-12">
      <div
        class="mb-6 flex items-center gap-2 text-[10px] font-bold tracking-[0.2em] text-primary uppercase"
      >
        <a href="/posts" class="hover:underline">Writing</a>
        <span class="text-muted-foreground/30">/</span>
        <span>Detail</span>
      </div>

      <h1
        class="mb-8 text-3xl leading-[1.4] font-bold text-foreground md:text-4xl"
      >
        {post.data.title}
      </h1>

      <div
        class="animate-in fade-in flex flex-wrap gap-2 font-mono text-[12px] tracking-tight duration-1000 md:gap-3"
      >
        <div
          class="flex items-center gap-3 rounded-full border border-border/40 bg-muted/40 px-3 py-1 text-muted-foreground"
        >
          <div class="flex items-center gap-1.5">
            <Icon name={"mdi:calendar-blank"} />
            <span
              id="post-date"
              data-updated={`${post.data.updatedAt ? "Updated " + formatDate(post.data.updatedAt) : "Not updated"}`}
              >{formatDate(post.data.createdAt)}{
                post.data.updatedAt ? " (edited)" : ""
              }</span
            >
          </div>
          <span class="h-3 w-px bg-border"></span>
          <a
            href={`/categories/${category.data.slug}`}
            class="flex cursor-pointer items-center gap-1.5 transition-colors hover:text-primary"
          >
            <Icon name={"mdi:category-outline"} />
            <span>{category.data.name}</span>
          </a>
        </div>

        <div
          class="flex items-center gap-4 rounded-full border border-border/20 bg-muted/20 px-3 py-1 text-muted-foreground/60"
        >
          <div class="flex items-center gap-1.5">
            <span class="post-words-count">{post.body?.length} </span>
            <span class="text-[10px] uppercase opacity-90">Words</span>
          </div>

          <div class="flex items-center gap-1.5">
            <span
              class="artalk-pv-count"
              data-page-key={Astro.url.pathname}
              class="font-bold text-foreground/80">-</span
            >
            <span class="text-[10px] uppercase opacity-90">Views</span>
          </div>

          <div class="flex items-center gap-1.5">
            <span
              class="artalk-comment-count"
              data-page-key={Astro.url.pathname}
              class="font-bold text-foreground/80">-</span
            >
            <span class="text-[10px] uppercase opacity-90">Comments</span>
          </div>
        </div>
      </div>
    </header>

    <TableOfContents headings={[]} />

    <div
      class:list={[
        "prose max-w-none dark:prose-invert",
        "prose-headings:tracking-tight",
        "prose-p:mb-8 prose-p:leading-loose prose-p:font-normal prose-p:text-muted-foreground",
        "prose-code:rounded-sm prose-code:bg-primary/15 prose-code:px-1.5 prose-code:py-0.5 prose-code:text-primary prose-code:before:content-none prose-code:after:content-none",
        "prose-",
      ]}
      data-pagefind-body
      set:html={finalHtml}
    />

    <div
      class="animate-in fade-in mt-12 mb-8 flex flex-wrap gap-2 duration-1000"
    >
      {
        tags.map((tag) => (
          <a
            href={`/tags/${tag.data.slug}`}
            class="group flex items-center gap-1.5 rounded-xl border border-border/50 bg-muted/30 px-3 py-1.5 transition-all hover:border-primary/40 hover:bg-card"
          >
            <span class="font-mono text-xs text-primary/40 italic group-hover:text-primary">
              #
            </span>
            <span class="text-xs font-medium text-muted-foreground transition-colors group-hover:text-foreground">
              {tag.data.name}
            </span>
          </a>
        ))
      }
    </div>
  </article>

  <footer class="mt-16 space-y-12 px-8 md:px-16">
    <div
      class="flex items-center justify-between border-t border-b border-border/50 py-5"
    >
      <a
        href="/posts"
        class="group flex items-center gap-2 text-sm text-muted-foreground hover:text-primary"
      >
        <span class="transition-transform group-hover:-translate-x-1">
          <Icon name="mdi:arrow-left" size={14} />
        </span> {site.labels.backToPosts}
      </a>
      <div
        class="font-mono text-[10px] tracking-widest text-muted-foreground/30 uppercase"
      >
        {site.labels.endOfPost}
      </div>
    </div>

    <Toast />
    <Comments />
  </footer>
</Layout>

<style is:global>
  .prose p {
    text-align: justify;
    word-break: break-word;
  }

  .post-words-count,
  .artalk-pv-count,
  .artalk-comment-count {
    color: var(--primary);
    font-weight: 400;
    opacity: 0.8;
  }

  #post-date {
    position: relative;
  }

  #post-date:hover:before {
    position: absolute;
    content: attr(data-updated);
    top: -33px;
    width: fit-content;
    border: 1px solid var(--border);
    border-radius: 2rem;
    text-align: center;
    background-color: var(--muted);
    padding: 2px 4px;
    flex-wrap: nowrap;
    color: var(--muted-foreground);
  }
</style>
