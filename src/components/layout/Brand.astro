---
import site from "@/config/site";
import { Image } from "astro:assets";
---

<div
  class="mb-6 flex items-center gap-4 md:mb-10 md:flex-col md:items-start md:gap-0"
>
  <div class="flex h-10 w-10 items-center justify-center md:h-11 md:w-11">
    <Image
      loading={"eager"}
      src={site.meta.logo}
      alt={"Site logo"}
      width={44}
      height={44}
      class="rounded-xl"
    />
  </div>
  <div class="md:mt-8">
    <h1
      data-pagefind-ignore
      class="text-lg font-bold tracking-tight text-foreground md:text-xl"
    >
      {site.meta.title}
    </h1>
    <p
      class="mt-2 hidden text-xs text-muted-foreground/70 md:block"
    >
      {site.meta.description}
    </p>
  </div>
</div>
