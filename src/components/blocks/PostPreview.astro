---
import { formatDate } from "@/utils/date";
import { Icon } from "astro-icon/components";
import type { CollectionEntry } from "astro:content";
import { getEntry } from "astro:content";
import site from "@/config/site";

interface Props {
  post: CollectionEntry<"posts">;
}

const { post } = Astro.props;
const category = await getEntry(
  post.data.category.collection,
  post.data.category.id,
);

// Auto-detect if post is new based on creation date
// Draft posts should not show "new" badge
const isNew = !post.data.draft && (post.data.new || (site.features.newPostDays > 0 &&
  (Date.now() - new Date(post.data.createdAt).getTime()) / (1000 * 60 * 60 * 24) <= site.features.newPostDays));
---

<article
  class="group flex cursor-pointer items-center justify-between border-b border-border/40 py-6 last:border-0"
>
  <div>
    <a
      href={`/posts/${post.id}`}
      class="inline-flex items-center gap-2 text-lg font-semibold text-foreground/80 transition-colors duration-300 group-hover:text-primary"
    >
      <span>{post.data.title}</span>
      {isNew && (
        <span class="rounded bg-primary/10 px-1.5 py-0.5 text-[10px] font-bold uppercase tracking-wider text-primary">
          New
        </span>
      )}
      {post.data.draft && (
        <span class="rounded bg-muted px-1.5 py-0.5 text-[10px] font-bold uppercase tracking-wider text-muted-foreground">
          Draft
        </span>
      )}
    </a>
    <p
      class="mt-2 font-mono text-[11px] text-muted-foreground italic opacity-60"
    >
      {formatDate(post.data.createdAt)} —
      <a href={`/categories/${category?.id}`} class="hover:text-primary">
        {category?.data.name}
      </a>
    </p>
  </div>
  <span class="text-border transition-all duration-300 group-hover:translate-x-1 group-hover:text-primary">
    <Icon name="mdi:arrow-right" />
  </span>
</article>
